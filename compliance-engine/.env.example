# Environment Configuration
# Copy this file to .env and update values as needed

# Application
APP_NAME=compliance-engine
APP_ENV=production
DEBUG=false
PORT=8000

# Database
# For local development: sqlite:///./app.db
# For Render Postgres: postgresql://user:pass@host/dbname
DATABASE_URL=sqlite:///./app.db

# CORS - Comma-separated list of allowed origins
# Add your Vercel frontend domain here
CORS_ORIGINS=https://YOUR-VERCEL-DOMAIN.vercel.app,http://localhost:3000

# File Storage
FILE_STORAGE_PATH=./storage/files

# Logging
LOG_LEVEL=INFO

# API
API_V1_PREFIX=/api/v1
